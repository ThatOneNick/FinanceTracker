<Window x:Class="FinanceTracker.AddIncomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinanceTracker"
        mc:Ignorable="d"
        Title="Add New Source of Income" Height="150" Width="300" WindowStartupLocation="CenterScreen">
    <Grid>
        <Label Content="Amount:" Margin="60,25,180,75" Height="25" Width="60"/>
        <Label Content="Source:" Margin="60,50,180,25" Height="25" Width="60"/>
        <TextBox x:Name="txtAmount" Margin="120,25,60,75" Text="Enter Amount" Height="25" Width="120"/>
        <TextBox x:Name="txtSource" Margin="120,50,60,25" Text="Enter Source" Height="25" Width="120"/>
        <Button x:Name="btnAdd" Content="Add" Margin="100,100,100,0" Height="25" Width="100" Click="btnAdd_Click"/>

    </Grid>
</Window>
